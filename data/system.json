    "hardware_management": [
      {
        "intent": "list_usb_devices",
        "description": "Lists usb devices connected in /dev/tty/USB and /dev/tty/ACM",
        "parameters": [],
        "command": "find /dev -maxdepth 1 \\( -name 'ttyUSB*' -o -name 'ttyACM*' \\) 2>/dev/null",
        "returns": "device_list"
      }
    ],
    "software_management": [
      {
