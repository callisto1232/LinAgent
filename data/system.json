[
{
  "system_skills": {
    "file_management": [
      {
        "intent": "find_latest_extension_file",
        "description": "Finds the most recently modified file by extension",
        "parameters": ["directory", "extension"],
        "command": "ls -t \"{directory}\"/*.{extension} 2>/dev/null | head -n 1",
        "returns": "file_path"
      },
      {
        "intent": "find_latest_file",
        "description": "Finds the most recently modified file",
        "parameters": ["directory", "extension"],
        "command": "ls -t \"{directory}\" 2>/dev/null | head -n 1",
        "returns": "file_path"
      },
      {
        "intent": "copy_to_directory",
        "description": "Copies a file to a spesific folder.",
        "parameters": ["file_path", "directory"],
        "command": "cp -r \"{file_path}\" \"{directory}\" ",
        "returns": "status"
      },
      {
        "intent": "move_to_directory",
        "description": "Moves a file to a spesific folder",
        "parameters": ["file_path", "directory"],
        "command": "mv \"{file_path}\" \"{directory}\" ",
        "returns": "status"
      },
      {
        "intent": "rename_file",
        "description": "Renames a file",
        "parameters": ["file_name", "new_name"],
        "command": "mv \"{file_name}\" \"{new_name}\" ",
        "returns": "status"
      },
      {
	"intent": "create_file",
	"description": "Creates a file with touch command",
	"parameters": ["file_name"],
	"command": "touch \"{file_name}\"",
	"returns": "status"
      },
      {
        "intent": "list_files",
        "description": "Lists all files in a spesific folder",
