[
{
  "system_skills": {
    "file_management": [
      {
        "intent": "find_latest_file",
        "description": "Finds the most recently modified file",
        "parameters": ["directory", "extension"],
        "command": "ls -t \"{directory}\"/*.{extension} 2>/dev/null | head -n 1",
        "returns": "file_path"
      },
      {
        "intent": "copy_to_directory",
        "description": "Copies a file to a spesific folder.",
        "parameters": ["file_path", "directory"],
        "command": "cp -r \"{file_path}\" \"{directory}\" ",
        "returns": "status"
      },
      {
        "intent": "move_to_directory",
        "description": "Moves a file to a spesific folder",
        "parameters": ["file_path", "directory"],
        "command": "mv \"{file_path}\" \"{directory}\" ",
        "returns": "status"
      },
      {
        "intent": "rename_file",
        "description": "Renames a file",
        "parameters": ["file_name", "new_name"],
        "command": "mv \"{file_name}\" \"{new_name}\" ",
        "returns": "status"
      },
      {
        "intent": "list_files",
        "description": "Lists all files in a spesific folder",
        "parameters": ["directory"],
        "command": "ls -1A \"{directory}\" ",
        "returns": "file_list"
      },
      {
        "intent": "change_directory",
        "description": "Changes directory to a spesific folder",
        "parameters": ["directory"],
        "command": "cd \"{directory}\" ",
        "returns": "status"
      },
      {
        "intent": "create_folder",
        "description": "Creates a new folder in a directory",
        "parameters": ["folder_name", "directory"],
        "command": "mkdir -p \"{directory}/{folder_name}\" ",
        "returns": "status"
      },
      {
        "intent": "delete_item",
        "description": "Removes a file or folder",
        "parameters": ["path"],
        "command": "rm -rf \"{path}\" ",
        "returns": "status"
      }
    ],
    "window_management": [
      {
        "intent": "change_workspace",
        "description": "Switches to a spesific virtual desktop in KDE6",
        "parameters": ["workspace_number"],
        "command": "qdbus6 org.kde.KWin /KWin org.kde.KWin.setCurrentDesktop {workspace_number}",
        "returns": "status"
      },
      {
        "intent": "get_current_workspace",
        "description": "Returns the ID of the currently active workspace",
        "parameters": [],
        "command": "qdbus6 org.kde.KWin /KWin org.kde.KWin.currentDesktop",
        "returns": "workspace_id"
      },
      {
        "intent": "capture_screen",
        "description": "Takes a full screenshot of the screen with Spectacle",
        "parameters": ["file_path"],
        "command": "spectacle -f -b -o \"{file_path}\"",
        "returns": "status"
      },
      {
        "intent": "launch_app",
        "description": "Starts an application in a detached session",
        "parameters": ["exec_cmd"],
        "command": "setsid {exec_cmd} >/dev/null 2>&1 &",
        "returns": "status"
      }
    ],
    "hardware_management": [
      {
        "intent": "list_usb_devices",
        "description": "Lists usb devices connected in /dev/tty/USB and /dev/tty/ACM",
        "parameters": [],
        "command": "find /dev -maxdepth 1 \\( -name 'ttyUSB*' -o -name 'ttyACM*' \\) 2>/dev/null",
        "returns": "device_list"
      }
    ],
    "software_management": [
      {
        "intent": "install_app",
        "description": "Downloads an app using Zypper package manager",
        "parameters": ["package_name"],
        "command": "sudo zypper --non-interactive in {package_name}",
        "returns": "status"
      },
      {
        "intent": "remove_app",
        "description": "Removes a downloaded app using Zypper package manager",
        "parameters": ["package_name"],
        "command": "sudo zypper --non-interactive remove {package_name}",
        "returns": "status"
      },
      {
        "intent": "system_update",
        "description": "Performs a full system update with Zypper dup",
        "parameters": [],
        "command": "sudo zypper --non-interactive dup",
        "returns": "status"
      },
      {
        "intent": "package_search",
        "description": "Searchs for a package in Zypper package manager",
        "parameters": ["package_name"],
        "command": "zypper se {package_name}",
        "returns": "search_results"
      }
    ],
    "general": [
      {
	"intent": "chat",
	"description": "Used for general conversation or questions that don't require executing any commands",
	"command": "echo '{message}'"
      }
    ]
  }
}
]
